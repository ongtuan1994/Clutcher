# --- Database (PostgreSQL) — required for login/register ---
# Copy this file to `.env` and run: `docker compose up -d` then `npx prisma migrate deploy`
# If login always fails with "database" errors, open http://localhost:4000/api/health while the API is running.
# Local (docker-compose): mapped to host port 5433 so it does not clash with other Postgres on 5432.
# postgresql://clutcher:clutcher@localhost:5433/clutcher
# Cloud SQL (recommended on GCP): use Secret Manager; Unix socket from Cloud Run:
# postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DATABASE_URL="postgresql://clutcher:clutcher@localhost:5433/clutcher"

JWT_SECRET="change-this-to-a-long-random-string-in-production"
PORT=4000

# Public URL of this API (used in JSON for avatar/sky image URLs when the web app is on another origin, e.g. Firebase Hosting)
# Example: https://clutcher-api-xxxxx-as.a.run.app
PUBLIC_API_URL=

# CORS: comma-separated allowed origins. Set your Firebase Hosting URL(s), e.g.
# https://your-project.web.app,https://your-project.firebaseapp.com
# Leave unset for development (reflect-request origin).
CORS_ORIGIN=

# --- Google Cloud Storage (optional; recommended on Cloud Run — disk is ephemeral) ---
# Bucket name. When set, avatars and sky images are stored in GCS instead of local /uploads.
GCS_BUCKET=
# Optional override for public object base (default: https://storage.googleapis.com/$GCS_BUCKET)
# GCS_PUBLIC_BASE_URL=

# --- Frontend build (Vite) — set when building for Firebase Hosting ---
# VITE_API_BASE_URL=https://your-cloud-run-url
